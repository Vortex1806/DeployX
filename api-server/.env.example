# Local dev default matches docker-compose.dev.yml. On the EC2 box, point
# this at the postgres service name instead (see ec2/docker-compose.yml).
DATABASE_URL=postgresql+psycopg2://deployx:devpassword@localhost:5432/deployx

# From `terraform output` in the terraform/ directory:
AWS_REGION=ap-south-1
ECS_CLUSTER=deployx-cluster
ECS_TASK_DEFINITION=deployx-build-worker
ECS_SUBNET_ID=subnet-xxxxxxxxxxxxxxxxx
ECS_SECURITY_GROUP_ID=sg-xxxxxxxxxxxxxxxxx
ECS_CONTAINER_NAME=build-worker

S3_BUCKET=deployx-outputs-xxxxxx
ROOT_DOMAIN=yourdomain.com
